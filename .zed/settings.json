{
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff"],
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
        },
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "autoImportCompletions": false,
        },
      },
    },
  },
}
